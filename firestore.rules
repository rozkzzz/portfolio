rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Portfolio is public: anyone can READ entries and profile.
    // WRITES are allowed only for a signed-in owner (the admin page,
    // public/admin.html). Create your single owner account in the
    // Firebase Console  ->  Authentication  ->  Email/Password.
    //
    // Tighter option: lock writes to one account by replacing
    //   request.auth != null
    // with your own uid, e.g.
    //   request.auth.uid == "PASTE_YOUR_UID_HERE"
    match /entries/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /profile/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
